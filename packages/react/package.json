{
  "name": "@relaya-chat/react",
  "version": "1.0.1",
  "private": false,
  "description": "Drop-in community chat component for React apps — real-time, moderated, WebSocket-based. Connects to the Relaya™ SaaS at api.relaya.chat. Embed with one line or go headless with hooks.",
  "keywords": [
    "chat",
    "real-time",
    "realtime",
    "community-chat",
    "react",
    "react-component",
    "websocket",
    "moderation",
    "live",
    "ugc",
    "embeddable",
    "radio",
    "component-library"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relaya-chat/sdk.git",
    "directory": "packages/react"
  },
  "homepage": "https://relaya.chat",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./admin": {
      "import": "./dist/admin.js",
      "types": "./dist/admin.d.ts"
    },
    "./styles": "./dist/relaya.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@relaya-chat/core": "^1.0.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.8"
  }
}
