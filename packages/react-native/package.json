{
  "name": "@relaya-chat/react-native",
  "version": "2.0.0-beta.4",
  "private": false,
  "description": "Real-time community chat hooks for React Native and Expo — OTP auth, WebSocket messaging, moderation. Connects to the Relaya™ SaaS at api.relaya.chat. Headless: bring your own UI.",
  "keywords": [
    "chat",
    "real-time",
    "realtime",
    "community-chat",
    "react-native",
    "expo",
    "websocket",
    "moderation",
    "radio",
    "live",
    "ugc",
    "hooks",
    "headless"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relaya-chat/sdk.git",
    "directory": "packages/react-native"
  },
  "homepage": "https://relaya.chat",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "dependencies": {
    "@relaya-chat/core": "2.0.0-beta.4"
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "react-dom": "^19.2.7",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
